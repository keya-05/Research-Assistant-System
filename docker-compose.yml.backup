services:
  backend:
    build: ./backend
    container_name: research_backend
    env_file:
      - ./backend/.env
    ports:
      - "8000:8000"
    restart: always

  frontend:
    build: ./frontend
    container_name: research_frontend
    ports:
      - "5173:5173"
    depends_on:
      - backend
    restart: always
