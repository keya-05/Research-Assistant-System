DATABASE_URL=postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]
SECRET_KEY=your-secret-key-for-jwt-tokens-change-in-production

# Google OAuth Configuration
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
#OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key   # used by research agent, free tier works
GOOGLE_API_KEY=your_google_api_key   # used by research agent, free tier works
TAVILY_API_KEY=your_tavily_api_key   # free tier works — used by research agent
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key #for dev-personal token used, have to create serivce token when deployed
LANGSMITH_PROJECT="My-Multi-Agent-Project"